{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.io/schemas/guardrail-fabric/devsecops-workroom-adversarial-aiops/v0.1.0",
  "title": "DevSecOpsWorkroomAdversarialAIOpsFixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_id",
    "fixture_class",
    "workroom_context",
    "input",
    "expected_decision",
    "expected_reason_codes",
    "non_claims"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1.0" },
    "fixture_id": { "type": "string", "pattern": "^guardrail-fixture:devsecops-workroom:" },
    "fixture_class": { "type": "string", "enum": ["poisoned_evidence", "unsafe_mutation_without_grant", "credential_sensitive_action", "safe_read_only_probe"] },
    "workroom_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workroom_ref", "lane", "incident_ref"],
      "properties": {
        "workroom_ref": { "type": "string", "pattern": "^workroom:devsecops:" },
        "lane": { "type": "string", "enum": ["pre_merge_validation", "post_merge_incident"] },
        "incident_ref": { "type": "string" },
        "topology_ref": { "type": "string" }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_type", "action_class", "summary", "has_action_grant", "requires_credential_access"],
      "properties": {
        "input_type": { "type": "string", "enum": ["log_evidence", "runbook_evidence", "remediation_action", "tool_probe"] },
        "action_class": { "type": "string", "enum": ["none", "read_only", "diagnostic_mutation", "reversible_mitigation", "irreversible_mutation", "credential_sensitive", "data_sensitive", "customer_visible", "destructive", "privileged_identity", "network_exposure", "production_change"] },
        "summary": { "type": "string", "minLength": 1 },
        "has_action_grant": { "type": "boolean" },
        "requires_credential_access": { "type": "boolean" },
        "contains_policy_override_attempt": { "type": "boolean" },
        "evidence_ref": { "type": "string" },
        "proposed_command_class": { "type": "string" }
      }
    },
    "expected_decision": { "type": "string", "enum": ["deny", "escalate", "allow", "allow_with_context"] },
    "expected_reason_codes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "non_claims": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  }
}
